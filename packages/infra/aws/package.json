{
  "name": "@infra/aws",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "lint": "eslint . --fix",
    "format": "prettier ./src --write"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:nest",
    "@nestjs/core": "catalog:nest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.982.0",
    "@aws-sdk/client-ses": "^3.982.0",
    "@aws-sdk/lib-storage": "^3.982.0",
    "@aws-sdk/s3-presigned-post": "^3.982.0",
    "@data/lib": "workspace:*",
    "es-toolkit": "catalog:common"
  },
  "devDependencies": {
    "@swc/core": "catalog:nest",
    "@system/eslint": "workspace:*",
    "@system/tsup": "workspace:*",
    "@system/typescript": "workspace:*",
    "@types/node": "catalog:common",
    "tsup": "catalog:common"
  }
}
