    "jsonwebtoken": "catalog:common"
  },
  "dependencies": {
    "@nestjs/jwt": "catalog:nest",
    "ioredis": "catalog:nest"
  },
  "devDependencies": {
    "@swc/core": "catalog:nest",
    "@system/eslint": "workspace:*",
    "@system/tsup": "workspace:*",
    "@system/typescript": "workspace:*",
    "@types/jsonwebtoken": "catalog:common",
    "tsup": "catalog:common"
  }
