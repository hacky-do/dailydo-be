{
  "name": "@system/tsup",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "lint": "eslint . --fix",
    "format": "prettier ./src --write"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@system/eslint": "workspace:*",
    "@system/typescript": "workspace:*",
    "@types/node": "catalog:common",
    "glob": "catalog:common",
    "tsup": "catalog:common"
  }
}
