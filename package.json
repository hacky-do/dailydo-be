{
  "name": "backend-api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "find . -type d -name .turbo -not -path '*/node_modules/*' -not -path '*/dist/*' -exec rm -rf {} +",
    "env": "turbo run env",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "prune": "turbo prune"
  },
  "devDependencies": {
    "eslint": "catalog:common",
    "lefthook": "^2.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "esbuild",
      "lefthook",
      "protobufjs"
    ]
  },
  "packageManager": "pnpm@10.28.1"
}
